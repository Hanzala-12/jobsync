# Copy to .env and fill values
OPENROUTER_API_KEY=
GROQ_API_KEY=gsk_your_free_key_here_or_sk-or-v1-for_openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: set model name to use on OpenRouter (defaults to gpt-4o-mini)
OPENROUTER_MODEL=gpt-4o-mini
DATABASE_URL=sqlite:///./jobsync.db
ENABLE_JOB_ARTIFACTS=false
PREFETCH_INTERVAL_HOURS=1
MAX_BG_WORKERS=5
MAX_PROFILE_UPLOAD_BYTES=5242880
SQLITE_TIMEOUT_SECONDS=30

# Additional keys (optional)
RAPIDAPI_KEY=your_rapidapi_key_for_jsearch
HUNTER_API_KEY=optional_for_email_lookup
