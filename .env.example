# Copy to .env and fill values
ENV=development
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=14
TESTING_MODE=false
TEST_USER_EMAIL=dev@example.com

OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=
NOVITA_API_KEY=
NOVITA_API_KEY_2=
GROQ_API_KEY=
GROQ_API_KEY_2=
OPENAI_API_KEY=
OPENAI_API_KEY_2=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: set base URL for OpenAI-compatible keys
OPENAI_BASE_URL=https://api.openai.com/v1
NOVITA_BASE_URL=https://api.novita.ai/openai
API_BASE_URL=http://localhost:8000/api
AUTH_BASE_URL=http://localhost:8000
# Resume PDF export is client-side via html2pdf.js; no extra backend key is needed.
# Optional: set model name to use on OpenRouter (defaults to gpt-4o-mini)
OPENROUTER_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
NOVITA_MODEL=deepseek/deepseek-v4-pro
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
CHROMA_DB_DIR=./chroma_db
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=jobfit_docs
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FINETUNED_EMBEDDING_MODEL_PATH=./models/finetuned-embeddings
ENABLE_FINETUNED_EMBEDDINGS=false
ENABLE_HYBRID_SEARCH=false
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5
HYBRID_CANDIDATE_LIMIT=200
ENABLE_AB_TESTING=false
LLM_FALLBACK_MODE=false
ENABLE_JOB_ARTIFACTS=true
ENABLE_CELERY=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_QUEUE_NAME=jobsync
ENABLE_METRICS=false
ALLOWED_INGESTION_DOMAINS=example.com,careers.example.edu
PREFETCH_INTERVAL_HOURS=1
PREFETCH_QUERIES=software engineer,data analyst,data scientist,product manager,designer,devops
MAX_BG_WORKERS=5
MAX_PROFILE_UPLOAD_BYTES=5242880
SQLITE_TIMEOUT_SECONDS=30
MAX_MATCH_RESULTS=50
MATCH_CACHE_TTL_DAYS=7
VITE_API_URL=http://localhost:8000/api
CORS_ORIGINS=["https://yourfrontend.com", "http://localhost:5173"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
RUN_STARTUP_MIGRATIONS=true
LOCAL_SQLITE_DB_PATH=./jobsync_local.db
RUN_JOB_SCHEDULER=false
SOURCE_TIMEOUT_SECONDS=8
ENABLE_PROFILE_INDEXING=false

# LLM model configuration variables
LLM_MODEL_OPENROUTER=meta-llama/llama-3.1-8b-instruct
LLM_MODEL_OPENROUTER_2=meta-llama/llama-3.1-8b-instruct
LLM_MODEL_GROQ=llama3-8b-8192
LLM_MODEL_GROQ_2=llama3-8b-8192
OPENROUTER_MODEL_2=gpt-4o-mini
OPENAI_MODEL_2=gpt-4o-mini
NOVITA_MODEL_2=deepseek/deepseek-v4-pro
LLM_PROVIDER=

# Additional production / scraper variables
SUPABASE_URL=
SUPABASE_ANON_KEY=
SCRAPER_TIMEOUT=30
SCRAPER_RATE_LIMIT_DELAY=2
SCRAPER_CONTACT_EMAIL=support@jobsync.pro
ENABLE_ON_DEMAND_SCRAPING=true
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)
ENABLE_JOB_SCRAPING=true
RAPIDAPI_KEY=
HUNTER_API_KEY=
# SearXNG is self-hosted and replaces any third-party search API key.
SEARXNG_TIMEOUT_SECONDS=12
SEARXNG_MAX_RESULTS=5
