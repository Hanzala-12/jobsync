# Copy to .env and fill values
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=
NOVITA_API_KEY=
NOVITA_API_KEY_2=
GROQ_API_KEY=
GROQ_API_KEY_2=
OPENAI_API_KEY=
OPENAI_API_KEY_2=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: set base URL for OpenAI-compatible keys
OPENAI_BASE_URL=https://api.openai.com/v1
NOVITA_BASE_URL=https://api.novita.ai/openai
# Optional: set model name to use on OpenRouter (defaults to gpt-4o-mini)
OPENROUTER_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
NOVITA_MODEL=deepseek/deepseek-v4-pro
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
CHROMA_DB_DIR=./chroma_db
LLM_FALLBACK_MODE=false
ENABLE_JOB_ARTIFACTS=false
PREFETCH_INTERVAL_HOURS=1
MAX_BG_WORKERS=5
MAX_PROFILE_UPLOAD_BYTES=5242880
SQLITE_TIMEOUT_SECONDS=30
ENABLE_STUDENT_MODULE=true
MAX_MATCH_RESULTS=50
MATCH_CACHE_TTL_DAYS=7
VITE_API_URL=http://localhost:8000/api
CORS_ORIGINS=["https://yourfrontend.com", "http://localhost:5173"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# LLM model configuration variables
LLM_MODEL_OPENROUTER=meta-llama/llama-3.1-8b-instruct
LLM_MODEL_GROQ=llama3-8b-8192

# Additional production / scraper variables
SUPABASE_URL=
SUPABASE_ANON_KEY=
SCRAPER_TIMEOUT=30
SCRAPER_RATE_LIMIT_DELAY=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)
ENABLE_JOB_SCRAPING=true
ENABLE_UNIVERSITY_SCRAPING=true
